#!/usr/bin/env bash
#
# pre-commit — block a commit if the repo is inconsistent.
#
# Runs scripts/check.sh (doctor + gen-packages --check). A failing check
# aborts the commit; bypass with `git commit --no-verify` if you must.
#
# Enable with scripts/install-hooks.sh (sets core.hooksPath to scripts/hooks).

set -euo pipefail

hook_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$hook_dir/../.." && pwd)"

exec "$repo_root/scripts/check.sh"
